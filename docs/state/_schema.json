{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec State File",
  "description": "Progress tracking for a spec. Path pattern: docs/state/{spec-id}.json. Companion event log: docs/state/{spec-id}.events.jsonl",
  "type": "object",
  "required": ["spec_id", "current_version", "target_version", "status"],
  "properties": {
    "spec_id": {
      "type": "string"
    },
    "current_version": {
      "type": "integer",
      "description": "The latest stable (implemented) version"
    },
    "target_version": {
      "type": "integer",
      "description": "The version being worked toward (equals current_version when idle)"
    },
    "status": {
      "type": "string",
      "enum": ["idle", "syncing", "in_progress", "verifying", "completed", "stable"],
      "description": "idle: no active work. syncing: diff analysis in progress. in_progress: tasks being worked. verifying: running verification. completed: all tasks done. stable: verified and promoted."
    },
    "tasks_total": {
      "type": "integer",
      "default": 0
    },
    "tasks_completed": {
      "type": "integer",
      "default": 0
    },
    "tasks_verified": {
      "type": "integer",
      "default": 0
    },
    "tasks_blocked": {
      "type": "integer",
      "default": 0
    },
    "last_synced": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "last_verified": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false,

  "$defs": {
    "event": {
      "title": "Spec Event (JSONL line)",
      "description": "One line in {spec-id}.events.jsonl. Append-only.",
      "type": "object",
      "required": ["timestamp", "type", "spec_id"],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "type": {
          "type": "string",
          "enum": [
            "SPEC_CREATED", "SPEC_DRAFTED", "SPEC_PROMOTED", "SPEC_DEPRECATED",
            "TASKS_GENERATED",
            "TASK_STARTED", "TASK_COMPLETED", "TASK_VERIFIED", "TASK_BLOCKED",
            "SYNC_STARTED", "SYNC_COMPLETED",
            "VERIFICATION_PASSED", "VERIFICATION_FAILED",
            "PREVIEW_GENERATED", "PREVIEW_OUTDATED"
          ]
        },
        "spec_id": { "type": "string" },
        "version": { "type": "integer" },
        "task_id": { "type": "string" },
        "task_count": { "type": "integer" },
        "description": { "type": "string" }
      }
    }
  }
}
